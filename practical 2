section .data
 m2 db 10,10, "Enter the String: "
 len_m2 equ $ - m2
 m3 db 10, "Entered string length is: "
 len_m3 equ $ - m3
section .bss
 srcstr resb 20
 count resb 1
 dispbuff resb 2
%macro disp 2 ; macro for printing message
 mov rax, 1 
; sys_write
 mov rdi, 1 
; stdout
 mov rsi, %1
 mov rdx, %2
 syscall
%endmacro
%macro acceptstr 2 ; macro for accepting string 
 mov rax, 0 ; sys_read
 mov rdi, 0 
 ; stdin
 mov rsi, %1
 mov rdx, %2
 syscall
%endmacro
section .text
 global _start
_start:
 disp m2, len_m2
 acceptstr srcstr, 20 ; read string
 dec rax ; remove newline
 mov [count], al
 disp m3, len_m3
 mov bl, [count]
 call display
 mov rax, 60 ; system exit
 mov rdi, 00
 syscall
display: 
 mov cl, 2
 mov rdi, dispbuff
d1: 
 rol bl, 4
 mov al, bl
 and al, 0fh
 cmp al, 9
 jbe d2
 add al, 7
d2:
 add al, 30h
 mov [rdi], al
 inc rdi
 dec cl
 jnz d1
 disp dispbuff, 2
 ret